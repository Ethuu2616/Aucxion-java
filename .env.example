# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=your_mysql_password
DB_USERNAME=root
DB_NAME=aucxion_db
DB_URL=jdbc:mysql://localhost:3306/aucxion_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true

# ─── Ports ────────────────────────────────────────────────────────────────────
BACKEND_PORT=8080
FRONTEND_PORT=3000
