{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Run Aucxion Backend",
      "request": "launch",
      "mainClass": "com.aucxion.AucxionApplication",
      "projectName": "aucxion-backend",
      "cwd": "${workspaceFolder}/backend",
      "vmArgs": "",
      "env": {}
    },
    {
      "type": "node",
      "name": "Run Aucxion Frontend",
      "request": "launch",
      "cwd": "${workspaceFolder}/frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Aucxion Full Stack",
      "configurations": ["Run Aucxion Backend", "Run Aucxion Frontend"]
    }
  ]
}
